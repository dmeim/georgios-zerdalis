# Public site URL (optional; used for absolute links / SEO when set)
# PUBLIC_SITE_URL=https://example.com

# Contact email shown in the footer / contact page
PUBLIC_CONTACT_EMAIL=hello@example.com

# n8n webhook for the contact form (client POST JSON: name, email, subject, message)
# Leave unset to validate the form without submitting (shows “not connected yet”)
# PUBLIC_N8N_WEBHOOK_URL=https://your-n8n.example/webhook/contact
