---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactInfo from '../components/contact/ContactInfo.astro';
import ContactForm from '../components/contact/ContactForm.astro';
import PageIntro from '../components/react/PageIntro';
import { contact, meta } from '../content/site';
---

<BaseLayout title="Contact" description={meta.description}>
  <section class="contact-page" aria-labelledby="contact-heading">
    <PageIntro
      client:visible
      title="Let's Connect"
      lede={contact.intro}
      titleId="contact-heading"
      className="contact-page__intro"
    />

    <div class="contact-grid">
      <ContactInfo />
      <ContactForm />
    </div>
  </section>
</BaseLayout>

<style>
  .contact-page {
    display: grid;
    gap: var(--space-2xl);
  }

  .contact-page :global(.page-intro) {
    margin-bottom: 0;
    max-width: 28rem;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: var(--space-3xl);
    align-items: start;
  }

  @media (max-width: 800px) {
    .contact-page {
      gap: var(--space-xl);
    }

    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }
  }
</style>
