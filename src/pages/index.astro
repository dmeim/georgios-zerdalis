---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeExperience from '../components/react/HomeExperience';
import {
  meta,
  hero,
  currentChapter,
  appointments,
  shortBio,
  mentorQuote,
  pedagogy,
  endorsement,
  venues,
} from '../content/site';

/** Served from public/images/ */
const heroPortrait = {
  src: '/images/George-Zerdalis-Hero.JPG',
  width: 4209,
  height: 6313,
};

const aboutPortrait = {
  src: '/images/George-Zerdalis-Jacket.jpeg',
  width: 3058,
  height: 4588,
};

const chapterImage = {
  src: '/images/Frost-School-Of-Music.jpg',
  width: 1200,
  height: 630,
};
---

<BaseLayout title="George Zerdalis" description={meta.description}>
  <HomeExperience
    client:load
    portraitSrc={heroPortrait.src}
    portraitWidth={heroPortrait.width}
    portraitHeight={heroPortrait.height}
    aboutPortraitSrc={aboutPortrait.src}
    aboutPortraitWidth={aboutPortrait.width}
    aboutPortraitHeight={aboutPortrait.height}
    hero={hero}
    chapter={currentChapter}
    chapterImageSrc={chapterImage.src}
    chapterImageWidth={chapterImage.width}
    chapterImageHeight={chapterImage.height}
    appointments={appointments}
    bio={shortBio}
    quote={mentorQuote}
    pedagogy={pedagogy}
    endorsement={endorsement}
    venues={venues}
  />
</BaseLayout>

<style is:global>
  /* Full-bleed home composition inside constrained .site-main */
  .site-main:has(.he) {
    width: 100%;
    max-width: none;
    margin-inline: 0;
    padding-block: 0;
  }

  /* Desktop only: overlay nav so hero centering uses the full viewport.
     Mobile keeps the normal in-flow sticky header so it doesn't cover the photo. */
  @media (min-width: 900px) {
    body:has(.he) .site-header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      width: 100%;
    }

    body:has(.he) .he-hero {
      min-height: 100dvh;
      min-height: 100svh;
    }
  }
</style>
