---
import BaseLayout from '../layouts/BaseLayout.astro';
import HomeExperience from '../components/react/HomeExperience';
import { getImage } from 'astro:assets';
import portrait from '../assets/portrait.jpeg';
import {
  meta,
  hero,
  currentChapter,
  appointments,
  shortBio,
  mentorQuote,
  pedagogy,
  endorsement,
  venues,
} from '../content/site';

const optimized = await getImage({
  src: portrait,
  width: 1920,
  format: 'webp',
  quality: 82,
});
---

<BaseLayout title="Georgios Zerdalis" description={meta.description}>
  <HomeExperience
    client:load
    portraitSrc={optimized.src}
    portraitWidth={optimized.attributes.width}
    portraitHeight={optimized.attributes.height}
    hero={hero}
    chapter={currentChapter}
    appointments={appointments}
    bio={shortBio}
    quote={mentorQuote}
    pedagogy={pedagogy}
    endorsement={endorsement}
    venues={venues}
  />
</BaseLayout>

<style is:global>
  /* Full-bleed home composition inside constrained .site-main */
  .site-main:has(.he) {
    width: 100%;
    max-width: none;
    margin-inline: 0;
    padding-block: 0;
  }

  /* Desktop only: overlay nav so hero centering uses the full viewport.
     Mobile keeps the normal in-flow sticky header so it doesn't cover the photo. */
  @media (min-width: 900px) {
    body:has(.he) .site-header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      width: 100%;
    }

    body:has(.he) .he-hero {
      min-height: 100dvh;
      min-height: 100svh;
    }
  }
</style>
