---
import path from "node:path";
import BaseLayout from "../layouts/BaseLayout.astro";
import GalleryGrid from "../components/react/GalleryGrid";
import PageIntro from "../components/react/PageIntro";
import { scanGallery } from "../lib/scanGallery";

const peers = scanGallery(path.join(process.cwd(), "public/gallery"));
const isEmpty = peers.length === 0;
---

<BaseLayout
  title="Gallery"
  description="Performance and studio images of George Zerdalis — timpanist and educator."
>
  <section class="gallery-page">
    <PageIntro
      client:visible
      lede="Moments from the stage and studio."
    />

    {
      isEmpty ? (
        <div class="gallery-page__empty">
          <div class="gallery-page__empty-frame" aria-hidden="true" />
          <p>No images yet — check back shortly.</p>
        </div>
      ) : (
        <GalleryGrid client:load peers={peers} />
      )
    }
  </section>
</BaseLayout>

<style>
  .gallery-page {
    display: grid;
    /* Match space below the lede; cancel the extra site-main top padding
       that used to sit above a large page title. */
    gap: var(--space-xl);
    margin-top: calc(var(--space-xl) - var(--space-2xl));
  }

  .gallery-page :global(.page-intro) {
    margin-bottom: 0;
  }

  .gallery-page__empty {
    display: grid;
    gap: var(--space-lg);
    justify-items: start;
    padding-block: var(--space-2xl);
    color: var(--color-ink-muted);
  }

  .gallery-page__empty p {
    margin: 0;
    max-width: 32ch;
    font-size: 0.9875rem;
    line-height: 1.6;
  }

  .gallery-page__empty-frame {
    width: min(100%, 16rem);
    aspect-ratio: 4 / 3;
    border: 1px solid var(--color-border);
    border-radius: var(--he-frame-radius);
    background:
      linear-gradient(
        135deg,
        transparent 47.5%,
        color-mix(in srgb, var(--color-primary) 28%, transparent) 49%,
        color-mix(in srgb, var(--color-primary) 28%, transparent) 51%,
        transparent 52.5%
      ),
      radial-gradient(
        ellipse at 30% 20%,
        var(--color-spot),
        transparent 55%
      ),
      var(--color-ground-elevated);
  }
</style>
