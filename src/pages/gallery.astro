---
import type { ImageMetadata } from 'astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import GalleryGrid from '../components/gallery/GalleryGrid.astro';
import GalleryLightbox from '../components/gallery/GalleryLightbox.astro';
import PageIntro from '../components/react/PageIntro';
import type { GalleryManifest } from '../components/gallery/types';
import { connect } from '../content/site';

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/gallery/**/*.{jpeg,jpg,png,webp,avif,gif}',
  { eager: true },
);

const videoModules = import.meta.glob<string>(
  '../assets/gallery/**/*.{mp4,webm,ogg,mov}',
  { eager: true, query: '?url', import: 'default' },
);

const imageMap: Record<string, ImageMetadata> = {};
for (const [path, mod] of Object.entries(imageModules)) {
  const filename = path.split('/').pop();
  if (filename) imageMap[filename] = mod.default;
}

const videoMap: Record<string, string> = {};
for (const [path, url] of Object.entries(videoModules)) {
  const filename = path.split('/').pop();
  if (filename) videoMap[filename] = url;
}

let manifest: GalleryManifest | null = null;
try {
  const mod = await import('../content/gallery.json');
  manifest = mod.default as GalleryManifest;
} catch {
  manifest = null;
}

const items = manifest?.items ?? [];
const status = manifest?.status ?? (items.length === 0 ? 'empty' : 'ready');
const isEmpty = items.length === 0;
const isPartial =
  status === 'partial' ||
  Boolean(manifest?.source?.toLowerCase().includes('temporary'));
const showMediaNote = isEmpty || isPartial;
---

<BaseLayout
  title="Gallery"
  description="Performance and studio images of Georgios Zerdalis — timpanist and educator."
>
  <section class="gallery-page">
    <PageIntro
      client:visible
      title="Gallery"
      lede="Selected moments from the stage and studio."
    />

    {
      showMediaNote && (
        <aside class="gallery-page__note" aria-live="polite">
          <p class="gallery-page__note-label">
            {isEmpty ? 'In preparation' : 'Working archive'}
          </p>
          {isEmpty ? (
            <p>
              The gallery is being prepared. High-quality images and video will
              appear here soon.
            </p>
          ) : (
            <p>
              Media shown here is temporary — sourced from Instagram until
              higher-resolution assets arrive.
            </p>
          )}
          <p class="gallery-page__note-link">
            Follow on{' '}
            <a
              href={connect.instagramUrl}
              target="_blank"
              rel="noopener noreferrer"
            >
              Instagram {connect.instagramHandle}
            </a>
          </p>
        </aside>
      )
    }

    {
      isEmpty ? (
        <div class="gallery-page__empty">
          <div class="gallery-page__empty-frame" aria-hidden="true" />
          <p>
            No images yet — check back shortly, or visit the Instagram profile
            above.
          </p>
        </div>
      ) : (
        <GalleryGrid items={items} imageMap={imageMap} videoMap={videoMap} />
      )
    }
  </section>

  <GalleryLightbox />
</BaseLayout>

<style>
  .gallery-page {
    display: grid;
    gap: var(--space-xl);
  }

  .gallery-page :global(.page-intro) {
    margin-bottom: 0;
  }

  .gallery-page__note {
    display: grid;
    gap: var(--space-sm);
    padding: var(--space-lg) 0;
    border-block: 1px solid var(--color-border);
    max-width: 40rem;
  }

  .gallery-page__note-label {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .gallery-page__note p {
    margin: 0;
    max-width: var(--measure);
    color: var(--color-ink-muted);
    font-size: 0.9875rem;
    line-height: 1.6;
  }

  .gallery-page__note-link {
    font-size: 0.9375rem;
  }

  .gallery-page__note-link a {
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-accent) 45%, transparent);
    transition:
      color var(--duration) var(--ease-out),
      border-color var(--duration) var(--ease-out);
  }

  .gallery-page__note-link a:hover {
    border-color: var(--color-accent);
  }

  .gallery-page__empty {
    display: grid;
    gap: var(--space-lg);
    justify-items: start;
    padding-block: var(--space-2xl);
    color: var(--color-ink-muted);
  }

  .gallery-page__empty p {
    margin: 0;
    max-width: 32ch;
    font-size: 0.9875rem;
    line-height: 1.6;
  }

  .gallery-page__empty-frame {
    width: min(100%, 16rem);
    aspect-ratio: 4 / 3;
    border: 1px solid var(--color-border);
    background:
      linear-gradient(
        135deg,
        transparent 47.5%,
        color-mix(in srgb, var(--color-accent) 28%, transparent) 49%,
        color-mix(in srgb, var(--color-accent) 28%, transparent) 51%,
        transparent 52.5%
      ),
      radial-gradient(
        ellipse at 30% 20%,
        var(--color-spot),
        transparent 55%
      ),
      var(--color-ground-elevated);
  }
</style>
