---
import { ClientRouter } from 'astro:transitions';
import { Sun, Moon } from '@lucide/astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Georgios Zerdalis',
  description = 'Timpanist & Educator — portfolio of Georgios Zerdalis.',
} = Astro.props;

const pageTitle =
  title === 'Georgios Zerdalis' ? title : `${title} · Georgios Zerdalis`;

const pathname = Astro.url.pathname;
const contactEmail =
  import.meta.env.PUBLIC_CONTACT_EMAIL ?? 'hello@example.com';

const nav = [
  { href: '/', label: 'Home' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/contact', label: 'Contact' },
] as const;

function isCurrent(href: string): boolean {
  if (href === '/') return pathname === '/' || pathname === '';
  return pathname === href || pathname.startsWith(`${href}/`);
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Source+Sans+3:ital,wght@0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <!-- FOUC-safe theme: apply before paint -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var prefersDark = window.matchMedia(
            '(prefers-color-scheme: dark)',
          ).matches;
          var theme =
            stored === 'light' || stored === 'dark'
              ? stored
              : prefersDark
                ? 'dark'
                : 'light';
          document.documentElement.setAttribute('data-theme', theme);
        } catch (_) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-brand" href="/">Georgios Zerdalis</a>
        <nav class="site-nav" aria-label="Primary">
          {
            nav.map(({ href, label }) => (
              <a
                href={href}
                aria-current={isCurrent(href) ? 'page' : undefined}
              >
                {label}
              </a>
            ))
          }
        </nav>
        <button
          type="button"
          class="theme-toggle"
          id="theme-toggle"
          aria-label="Toggle color theme"
        >
          <Sun class="icon-sun" aria-hidden="true" />
          <Moon class="icon-moon" aria-hidden="true" />
        </button>
      </div>
    </header>

    <main class="site-main" id="main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <p>&copy; {new Date().getFullYear()} Georgios Zerdalis</p>
        <div class="site-footer__links">
          <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
          <a
            href="https://www.instagram.com/georgezerdalis/"
            target="_blank"
            rel="noopener noreferrer"
          >
            Instagram
          </a>
        </div>
      </div>
    </footer>

    <script is:inline>
      (function () {
        function currentTheme() {
          return (
            document.documentElement.getAttribute('data-theme') || 'dark'
          );
        }

        function setTheme(theme) {
          document.documentElement.setAttribute('data-theme', theme);
          try {
            localStorage.setItem('theme', theme);
          } catch (_) {}
        }

        function onToggle() {
          setTheme(currentTheme() === 'dark' ? 'light' : 'dark');
        }

        function bind() {
          var btn = document.getElementById('theme-toggle');
          if (!btn || btn.dataset.bound === '1') return;
          btn.dataset.bound = '1';
          btn.addEventListener('click', onToggle);
        }

        bind();
        document.addEventListener('astro:page-load', bind);
      })();
    </script>
  </body>
</html>
