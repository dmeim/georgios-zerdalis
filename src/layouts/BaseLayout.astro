---
import { ClientRouter } from 'astro:transitions';
import SiteEffects from '../components/react/SiteEffects';
import '../styles/global.css';

// Developer experiment toggles for the 4-layer chrome waves on header/footer.
const SHOW_HEADER_WAVES = false;
const SHOW_FOOTER_WAVES = false;

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'George Zerdalis',
  description = 'Timpanist, Percussionist, and Educator — portfolio of George Zerdalis.',
} = Astro.props;

const pageTitle =
  title === 'George Zerdalis' ? title : `${title} · George Zerdalis`;

const pathname = Astro.url.pathname;

const siteOrigin = (
  import.meta.env.PUBLIC_SITE_URL ||
  Astro.site?.href ||
  ''
)
  .toString()
  .replace(/\/$/, '');

const canonicalUrl = siteOrigin
  ? `${siteOrigin}${pathname === '/' ? '' : pathname}`
  : undefined;

const ogImagePath = '/images/og-image.jpg';
const ogImageUrl = siteOrigin ? `${siteOrigin}${ogImagePath}` : ogImagePath;

const nav = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/connect', label: 'Connect' },
] as const;

function isCurrent(href: string): boolean {
  if (href === '/') return pathname === '/' || pathname === '';
  return pathname === href || pathname.startsWith(`${href}/`);
}

const year = new Date().getFullYear();
---

<!doctype html>
<html
  lang="en"
  data-page={pathname === '/connect' || pathname.startsWith('/connect/') ? 'connect' : undefined}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Portrait of George Zerdalis" />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {siteOrigin && <meta property="og:site_name" content="George Zerdalis" />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,300;0,500;0,700;1,300;1,500&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <!-- FOUC-safe theme: apply before paint -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var pref =
            stored === 'light' || stored === 'system' || stored === 'dark'
              ? stored
              : 'system';
          var prefersDark = window.matchMedia(
            '(prefers-color-scheme: dark)',
          ).matches;
          var theme =
            pref === 'light' || pref === 'dark'
              ? pref
              : prefersDark
                ? 'dark'
                : 'light';
          document.documentElement.setAttribute('data-theme-pref', pref);
          document.documentElement.setAttribute('data-theme', theme);
        } catch (_) {
          document.documentElement.setAttribute('data-theme-pref', 'system');
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="site-brand" href="/">George Zerdalis</a>

        <div class="site-header__center">
          <nav class="site-nav segment-track" aria-label="Primary">
            {
              nav.map(({ href, label }) => (
                <a
                  href={href}
                  aria-current={isCurrent(href) ? 'page' : undefined}
                >
                  {label}
                </a>
              ))
            }
          </nav>

          <div class="nav-menu">
            <button
              type="button"
              class="nav-toggle"
              id="nav-toggle"
              aria-label="Open menu"
              aria-controls="mobile-nav"
              aria-expanded="false"
            >
              <span class="nav-toggle__bars" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
              </span>
            </button>

            <nav
              class="mobile-nav"
              id="mobile-nav"
              aria-label="Mobile"
              data-open="false"
            >
              <div class="site-nav segment-track">
                {
                  nav.map(({ href, label }) => (
                    <a
                      href={href}
                      aria-current={isCurrent(href) ? 'page' : undefined}
                    >
                      {label}
                    </a>
                  ))
                }
              </div>
            </nav>
          </div>
        </div>

        <div class="site-header__actions">
          <div id="theme-toggle-host" class="theme-toggle-host"></div>
        </div>

        {SHOW_HEADER_WAVES && (
          <div class="site-header__waves" aria-hidden="true">
            <span class="chrome-wave chrome-wave--a"></span>
            <span class="chrome-wave chrome-wave--b"></span>
            <span class="chrome-wave chrome-wave--c"></span>
            <span class="chrome-wave chrome-wave--solid"></span>
          </div>
        )}
      </div>
    </header>

    <div class="site-scroll-veil" aria-hidden="true"></div>

    <main class="site-main" id="main">
      <slot />
    </main>

    <footer class="site-footer">
      {SHOW_FOOTER_WAVES && (
        <div class="site-footer__waves" aria-hidden="true">
          <span class="chrome-wave chrome-wave--a"></span>
          <span class="chrome-wave chrome-wave--b"></span>
          <span class="chrome-wave chrome-wave--c"></span>
          <span class="chrome-wave chrome-wave--solid"></span>
        </div>
      )}
      <p class="site-footer__line">
        &copy; {year} George Zerdalis - Timpanist, Percussionist, and Educator
      </p>
    </footer>

    <SiteEffects client:load />

    <script>
      import '../scripts/theme-toggle';
      import '../scripts/nav-thumb';
    </script>

    <script is:inline>
      (function () {
        function setClosed(toggle, popover) {
          popover.setAttribute('data-open', 'false');
          popover.classList.remove('is-open');
          toggle.setAttribute('aria-expanded', 'false');
          toggle.setAttribute('aria-label', 'Open menu');
        }

        function setOpen(toggle, popover) {
          popover.setAttribute('data-open', 'true');
          popover.classList.add('is-open');
          toggle.setAttribute('aria-expanded', 'true');
          toggle.setAttribute('aria-label', 'Close menu');
        }

        function bindMobileNav() {
          var toggle = document.getElementById('nav-toggle');
          var popover = document.getElementById('mobile-nav');
          var menu = toggle && toggle.closest('.nav-menu');
          if (!toggle || !popover || !menu) return;

          function isOpen() {
            return popover.getAttribute('data-open') === 'true';
          }

          function openNav() {
            setOpen(toggle, popover);
            var first = popover.querySelector('a[href]');
            if (first) first.focus();
          }

          function closeNav(restoreFocus) {
            setClosed(toggle, popover);
            if (restoreFocus) toggle.focus();
          }

          // Reset after client navigations
          closeNav(false);

          if (toggle.dataset.bound === '1') return;
          toggle.dataset.bound = '1';

          toggle.addEventListener('click', function (e) {
            e.stopPropagation();
            if (isOpen()) closeNav(false);
            else openNav();
          });

          popover.addEventListener('click', function (e) {
            if (e.target.tagName === 'A') closeNav(false);
          });

          if (!window.__gzNavListeners) {
            window.__gzNavListeners = true;

            document.addEventListener('pointerdown', function (e) {
              var t = document.getElementById('nav-toggle');
              var d = document.getElementById('mobile-nav');
              var m = t && t.closest('.nav-menu');
              if (!t || !d || !m || d.getAttribute('data-open') !== 'true')
                return;
              if (m.contains(e.target)) return;
              setClosed(t, d);
            });

            document.addEventListener('keydown', function (e) {
              var t = document.getElementById('nav-toggle');
              var d = document.getElementById('mobile-nav');
              if (!t || !d || d.getAttribute('data-open') !== 'true') return;

              if (e.key === 'Escape') {
                e.preventDefault();
                setClosed(t, d);
                t.focus();
              }
            });

            window.addEventListener('resize', function () {
              if (!window.matchMedia('(min-width: 769px)').matches) return;
              var t = document.getElementById('nav-toggle');
              var d = document.getElementById('mobile-nav');
              if (!t || !d || d.getAttribute('data-open') !== 'true') return;
              setClosed(t, d);
            });
          }
        }

        bindMobileNav();
        document.addEventListener('astro:page-load', bindMobileNav);
      })();
    </script>
  </body>
</html>
