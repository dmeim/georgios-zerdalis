---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { GalleryItem } from './types';
import GalleryVideo from './GalleryVideo.astro';

interface Props {
  items: GalleryItem[];
  imageMap: Record<string, ImageMetadata>;
  videoMap: Record<string, string>;
}

const { items, imageMap, videoMap } = Astro.props;

function resolveImage(item: GalleryItem): ImageMetadata | undefined {
  if (!item.filename) return undefined;
  return imageMap[item.filename];
}

function resolveVideoSrc(item: GalleryItem): string | undefined {
  if (item.embedUrl) return undefined;
  if (item.filename && videoMap[item.filename]) return videoMap[item.filename];
  if (item.src?.startsWith('http') || item.src?.startsWith('/')) return item.src;
  if (item.src && videoMap[item.src]) return videoMap[item.src];
  return item.src;
}

function resolvePoster(item: GalleryItem): string | undefined {
  if (!item.poster) return undefined;
  const meta = imageMap[item.poster];
  return meta?.src;
}
---

<ul class="gallery-grid" role="list">
  {
    items.map((item, index) => {
      const caption = item.caption?.trim() || '';
      const alt = item.alt?.trim() || caption || 'Gallery media';

      if (item.type === 'video') {
        const videoSrc = resolveVideoSrc(item);
        const poster = resolvePoster(item);
        return (
          <li class="gallery-grid__item gallery-grid__item--video">
            <GalleryVideo item={item} src={videoSrc} poster={poster} />
            {caption && <p class="gallery-grid__caption">{caption}</p>}
          </li>
        );
      }

      const image = resolveImage(item);
      if (!image) {
        return (
          <li class="gallery-grid__item gallery-grid__item--missing">
            <div class="gallery-grid__missing" role="status">
              <span>{alt}</span>
              <span class="gallery-grid__missing-note">Media pending</span>
            </div>
          </li>
        );
      }

      return (
        <li class="gallery-grid__item">
          <button
            type="button"
            class="gallery-grid__trigger"
            data-gallery-open
            data-gallery-src={image.src}
            data-gallery-alt={alt}
            data-gallery-caption={caption}
            aria-label={`View ${alt}`}
          >
            <Image
              src={image}
              alt={alt}
              widths={[320, 480, 640, 960]}
              sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 280px"
              loading={index < 4 ? 'eager' : 'lazy'}
              decoding="async"
              class="gallery-grid__img"
            />
            {caption && (
              <span class="gallery-grid__caption gallery-grid__caption--overlay">
                {caption}
              </span>
            )}
          </button>
        </li>
      );
    })
  }
</ul>

<style>
  .gallery-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-md);
  }

  @media (min-width: 640px) {
    .gallery-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--space-lg);
    }
  }

  @media (min-width: 1024px) {
    .gallery-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .gallery-grid__item {
    margin: 0;
    min-width: 0;
  }

  .gallery-grid__item--video {
    grid-column: 1 / -1;
  }

  @media (min-width: 640px) {
    .gallery-grid__item--video {
      grid-column: span 2;
    }
  }

  .gallery-grid__trigger {
    position: relative;
    display: block;
    width: 100%;
    padding: 0;
    border: 1px solid var(--color-border);
    background: var(--color-ground-elevated);
    cursor: zoom-in;
    overflow: hidden;
    text-align: left;
    transition:
      border-color var(--duration) var(--ease-out),
      transform var(--duration) var(--ease-out);
  }

  .gallery-grid__trigger:hover,
  .gallery-grid__trigger:focus-visible {
    border-color: var(--color-accent-soft);
    transform: translateY(-2px);
  }

  .gallery-grid__img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    transition: transform 400ms var(--ease-out);
  }

  .gallery-grid__trigger:hover .gallery-grid__img,
  .gallery-grid__trigger:focus-visible .gallery-grid__img {
    transform: scale(1.03);
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-grid__trigger,
    .gallery-grid__img {
      transition: none;
    }

    .gallery-grid__trigger:hover,
    .gallery-grid__trigger:focus-visible {
      transform: none;
    }

    .gallery-grid__trigger:hover .gallery-grid__img,
    .gallery-grid__trigger:focus-visible .gallery-grid__img {
      transform: none;
    }
  }

  .gallery-grid__caption {
    margin: var(--space-sm) 0 0;
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    max-width: none;
  }

  .gallery-grid__caption--overlay {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    margin: 0;
    padding: var(--space-lg) var(--space-sm) var(--space-sm);
    background: linear-gradient(
      to top,
      color-mix(in srgb, var(--color-ground) 88%, transparent),
      transparent
    );
    color: var(--color-ink);
    font-size: 0.8125rem;
    line-height: 1.35;
  }

  .gallery-grid__missing {
    display: grid;
    place-content: center;
    gap: var(--space-xs);
    aspect-ratio: 1;
    padding: var(--space-md);
    border: 1px dashed var(--color-border);
    color: var(--color-ink-muted);
    text-align: center;
    font-size: 0.875rem;
  }

  .gallery-grid__missing-note {
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-accent-soft);
  }
</style>
