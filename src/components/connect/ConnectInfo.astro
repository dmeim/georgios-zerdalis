---
/**
 * Connect details — sourced from `src/content/site.ts`.
 * Page heading lives in connect.astro via PageIntro.
 */
import { Mail, MapPin, UsersRound } from '@lucide/astro';
import { connect } from '../../content/site';
---

<div class="connect-info">
  <ul class="connect-details" role="list">
    <li class="connect-item">
      <span class="connect-item__icon" aria-hidden="true">
        <Mail size={20} stroke-width={1.75} />
      </span>
      <div class="connect-item__content">
        <a href={`mailto:${connect.email}`}>{connect.email}</a>
      </div>
    </li>
    <li class="connect-item">
      <span class="connect-item__icon" aria-hidden="true">
        <UsersRound size={20} stroke-width={1.75} />
      </span>
      <div class="connect-item__content">
        <a
          href={connect.instagramUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          {connect.instagramHandle}
        </a>
      </div>
    </li>
    <li class="connect-item">
      <span class="connect-item__icon" aria-hidden="true">
        <MapPin size={20} stroke-width={1.75} />
      </span>
      <div class="connect-item__content">
        <p>{connect.location}</p>
        <p>{connect.locationDetail}</p>
      </div>
    </li>
  </ul>
</div>

<style>
  .connect-details {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .connect-item {
    display: flex;
    gap: var(--space-md);
    align-items: center;
  }

  .connect-item__icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid color-mix(in srgb, var(--color-secondary) 40%, transparent);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--color-ground-elevated) 80%, transparent);
    color: var(--color-secondary);
  }

  .connect-item__content {
    min-width: 0;
  }

  .connect-item__content a,
  .connect-item__content p {
    margin: 0;
    color: var(--color-ink);
    text-decoration: none;
    word-break: break-word;
    font-size: 1.0625rem;
    line-height: 1.45;
  }

  .connect-item__content a {
    transition: color var(--duration) var(--ease-out);
  }

  .connect-item__content a:hover {
    color: var(--color-secondary);
  }
</style>
