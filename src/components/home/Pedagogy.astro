---
import { pedagogy } from '../../content/site';
---

<section class="pedagogy reveal" aria-labelledby="pedagogy-title">
  <header class="pedagogy__header">
    <p class="pedagogy__eyebrow">Pedagogy</p>
    <h2 id="pedagogy-title" class="pedagogy__title">How Georgios teaches</h2>
  </header>

  <ul class="pedagogy__list">
    {
      pedagogy.map((item) => (
        <li class="pedagogy__item">{item}</li>
      ))
    }
  </ul>
</section>

<style>
  .pedagogy {
    padding-block: var(--space-3xl);
    border-bottom: 1px solid var(--color-border);
  }

  .pedagogy__header {
    margin-bottom: var(--space-2xl);
  }

  .pedagogy__eyebrow {
    margin: 0 0 var(--space-md);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .pedagogy__title {
    margin: 0;
    max-width: 14ch;
  }

  .pedagogy__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0;
    max-width: 42rem;
  }

  .pedagogy__item {
    padding-block: var(--space-lg);
    border-top: 1px solid var(--color-border);
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.2vw, 1.45rem);
    line-height: 1.35;
    color: var(--color-ink);
  }

  .pedagogy__item:last-child {
    border-bottom: 1px solid var(--color-border);
  }
</style>
