---
import { endorsement } from '../../content/site';
---

<section class="endorsement reveal" aria-label="Artist endorsement">
  <p class="endorsement__whisper">
    <a
      class="endorsement__link"
      href={endorsement.url}
      target="_blank"
      rel="noopener noreferrer"
    >
      {endorsement.label}
    </a>
  </p>
</section>

<style>
  .endorsement {
    padding-block: var(--space-2xl);
    border-bottom: 1px solid var(--color-border);
    text-align: center;
  }

  .endorsement__whisper {
    margin: 0;
    max-width: none;
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .endorsement__link {
    color: var(--color-ink-muted);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition:
      color var(--duration) var(--ease-out),
      border-color var(--duration) var(--ease-out);
  }

  .endorsement__link:hover {
    color: var(--color-primary);
    border-bottom-color: color-mix(in srgb, var(--color-primary) 40%, transparent);
  }
</style>
