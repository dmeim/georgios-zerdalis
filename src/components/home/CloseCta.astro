---
---

<section class="close-cta reveal" aria-labelledby="close-cta-title">
  <h2 id="close-cta-title" class="close-cta__title">Begin a conversation</h2>
  <p class="close-cta__body">
    For collaborations, lessons, or inquiries — Georgios welcomes your message.
  </p>
  <a class="close-cta__button" href="/connect">Get in Touch</a>
</section>

<style>
  .close-cta {
    padding-block: var(--space-3xl);
    text-align: center;
  }

  .close-cta__title {
    margin: 0 0 var(--space-md);
  }

  .close-cta__body {
    margin: 0 auto var(--space-xl);
    max-width: 36ch;
    color: var(--color-ink-muted);
  }

  .close-cta__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0.7rem 1.5rem;
    border-radius: var(--radius);
    background: var(--color-secondary);
    border: 1px solid var(--color-secondary);
    color: var(--color-ink-on-secondary);
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    transition:
      background-color var(--duration) var(--ease-out),
      border-color var(--duration) var(--ease-out),
      color var(--duration) var(--ease-out);
  }

  .close-cta__button:hover {
    background: color-mix(in srgb, var(--color-secondary) 88%, var(--color-ink));
    border-color: color-mix(in srgb, var(--color-secondary) 88%, var(--color-ink));
    color: var(--color-ink-on-secondary);
  }
</style>
