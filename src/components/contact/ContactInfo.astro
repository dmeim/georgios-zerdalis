---
/**
 * Contact details — sourced from `src/content/site.ts`.
 * Page heading lives in contact.astro via PageIntro.
 */
import { Mail, MapPin, AtSign } from '@lucide/astro';
import { contact } from '../../content/site';
---

<div class="contact-info">
  <ul class="contact-details" role="list">
    <li class="contact-item">
      <span class="contact-item__icon" aria-hidden="true">
        <Mail size={20} stroke-width={1.75} />
      </span>
      <div class="contact-item__content">
        <span class="contact-item__label">Email</span>
        <a href={`mailto:${contact.email}`}>{contact.email}</a>
      </div>
    </li>
    <li class="contact-item">
      <span class="contact-item__icon" aria-hidden="true">
        <MapPin size={20} stroke-width={1.75} />
      </span>
      <div class="contact-item__content">
        <span class="contact-item__label">Location</span>
        <p>{contact.location}</p>
        <p class="contact-item__detail">{contact.locationDetail}</p>
      </div>
    </li>
    <li class="contact-item">
      <span class="contact-item__icon" aria-hidden="true">
        <AtSign size={20} stroke-width={1.75} />
      </span>
      <div class="contact-item__content">
        <span class="contact-item__label">Instagram</span>
        <a
          href={contact.instagramUrl}
          target="_blank"
          rel="noopener noreferrer"
        >
          {contact.instagramHandle}
        </a>
      </div>
    </li>
  </ul>
</div>

<style>
  .contact-details {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .contact-item {
    display: flex;
    gap: var(--space-md);
    align-items: flex-start;
  }

  .contact-item__icon {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-ground-elevated) 80%, transparent);
    color: var(--color-accent);
  }

  .contact-item__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
    min-width: 0;
    padding-top: 0.2rem;
  }

  .contact-item__label {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .contact-item__content a,
  .contact-item__content p {
    margin: 0;
    color: var(--color-ink);
    text-decoration: none;
    word-break: break-word;
    font-size: 1.0625rem;
    line-height: 1.45;
  }

  .contact-item__content a {
    transition: color var(--duration) var(--ease-out);
  }

  .contact-item__content a:hover {
    color: var(--color-accent);
  }

  .contact-item__detail {
    font-size: 0.9375rem !important;
    color: var(--color-ink-muted) !important;
  }
</style>
